{
  "realm": "platinumcoin",
  "enabled": true,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"min\":3,\"max\":255}}},{\"name\":\"email\",\"displayName\":\"${email}\",\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"email\":{}}},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255}}},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255}}},{\"name\":\"accountId\",\"displayName\":\"Account ID\",\"permissions\":{\"view\":[\"admin\"],\"edit\":[\"admin\"]}},{\"name\":\"cpf\",\"displayName\":\"CPF\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]},\"validations\":{\"pattern\":{\"pattern\":\"^\\\\d{11}$\",\"error-message\":\"CPF deve ter 11 digitos\"}}}],\"groups\":[]}"
          ]
        }
      }
    ]
  },
  "clientScopes": [
    {
      "name": "account",
      "description": "Claims de conta PlatinumCoin (accountId)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "accountId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "accountId",
            "claim.name": "accountId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "platinumcoin-harness",
      "name": "Harness (login dev/teste)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "defaultClientScopes": ["profile", "email", "roles", "web-origins", "basic", "acr", "account"],
      "optionalClientScopes": []
    },
    {
      "clientId": "auth-service-admin",
      "name": "auth-service (Admin API, service account)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "test-admin-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "users": [
    {
      "username": "alice@platinumcoin.dev",
      "email": "alice@platinumcoin.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Platinum",
      "attributes": {
        "accountId": ["7f8b1e7e-2a4d-4d6e-9c1a-5b3f2a9d0c11"],
        "cpf": ["39053344705"]
      },
      "credentials": [
        { "type": "password", "value": "Seed@12345", "temporary": false }
      ]
    },
    {
      "username": "service-account-auth-service-admin",
      "enabled": true,
      "serviceAccountClientId": "auth-service-admin",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users"]
      }
    }
  ]
}
