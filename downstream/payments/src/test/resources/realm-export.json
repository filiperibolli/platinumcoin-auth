{
  "realm": "platinumcoin",
  "enabled": true,
  "accessTokenLifespan": 300,
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"min\":3,\"max\":255}}},{\"name\":\"email\",\"displayName\":\"${email}\",\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"email\":{}}},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255}}},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"validations\":{\"length\":{\"max\":255}}},{\"name\":\"accountId\",\"displayName\":\"Account ID\",\"permissions\":{\"view\":[\"admin\"],\"edit\":[\"admin\"]}}],\"groups\":[]}"
          ]
        }
      }
    ]
  },
  "roles": {
    "realm": [
      { "name": "customer", "description": "Cliente da fintech: pode enviar Pix" }
    ]
  },
  "clientScopes": [
    {
      "name": "roles",
      "description": "Realm roles no access token (realm_access.roles)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "account",
      "description": "Claims de conta PlatinumCoin (accountId)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "accountId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "accountId",
            "claim.name": "accountId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "payments",
      "description": "Audiência do platinumcoin-payments",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "payments-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "platinumcoin-payments",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "platinumcoin-harness",
      "name": "Harness (login dev/teste)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "defaultClientScopes": ["roles", "account", "payments"],
      "optionalClientScopes": []
    },
    {
      "clientId": "other-service-harness",
      "name": "Harness de outro serviço (sem a audiência do payments)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "defaultClientScopes": ["roles", "account"],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "alice@platinumcoin.dev",
      "email": "alice@platinumcoin.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Platinum",
      "realmRoles": ["customer"],
      "attributes": {
        "accountId": ["7f8b1e7e-2a4d-4d6e-9c1a-5b3f2a9d0c11"]
      },
      "credentials": [
        { "type": "password", "value": "Seed@12345", "temporary": false }
      ]
    },
    {
      "username": "carol@platinumcoin.dev",
      "email": "carol@platinumcoin.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Carol",
      "lastName": "Support",
      "attributes": {
        "accountId": ["9a1c3d5e-7b2f-4a8c-8d0e-1f2a3b4c5d6e"]
      },
      "credentials": [
        { "type": "password", "value": "Seed@12345", "temporary": false }
      ]
    }
  ]
}
